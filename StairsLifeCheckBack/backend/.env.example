# ============================================================
# StairsLife Backend — Environment
# ============================================================

# --- Server ---
PORT=3000
NODE_ENV=development
APP_URL=http://localhost:5173   # URL frontend (untuk link di email & Xendit redirect)

# --- CORS ---
FRONTEND_URL=http://localhost:5173

# --- Database (Supabase Postgres) ---
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DBNAME

# --- Supabase ---
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# --- JWT (dua secret berbeda) ---
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# --- Upload ---
PUBLIC_BASE_URL=

# ============================================================
# Email (Resend)
# ============================================================
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=StairsLife <noreply@stairslife.id>

# ============================================================
# Google OAuth
# ============================================================
GOOGLE_CLIENT_ID=xxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxx
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback

# ============================================================
# Xendit (Payment Gateway)
# ============================================================
# Dapatkan dari Xendit Dashboard → Settings → API Keys.
# Pakai "Development API Key" dulu untuk test.
# Format: xnd_development_... atau xnd_production_...
XENDIT_SECRET_KEY=xnd_development_xxxxxxxxxxxxx

# Callback verification token. Dapatkan dari Xendit Dashboard →
# Settings → Webhooks → "Callback verification token".
# Token ini WAJIB sama dengan yang dikirim Xendit di header
# `x-callback-token` setiap webhook. Tanpa ini, semua webhook
# ditolak (mode aman).
XENDIT_CALLBACK_TOKEN=xnd_callback_xxxxxxxxxxxxx

# URL webhook yang harus didaftarkan di Xendit Dashboard:
#   Invoice paid/expired: {PUBLIC_BASE_URL}/api/v1/payments/webhook/xendit
#   Disbursement:         {PUBLIC_BASE_URL}/api/v1/withdrawals/webhook/xendit
#
# Untuk dev, expose localhost ke internet pakai ngrok / cloudflared:
#   ngrok http 3000
#   → kasih URL https://xxx.ngrok-free.app ke Xendit Dashboard

# ============================================================
# Withdrawal Settings
# ============================================================
# Fee admin per withdrawal (Rupiah)
WITHDRAWAL_ADMIN_FEE=2500

# Minimum withdrawal amount (Rupiah)
WITHDRAWAL_MIN_AMOUNT=50000
