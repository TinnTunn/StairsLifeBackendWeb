generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model announcements {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title      String    @db.VarChar(255)
  body       String
  target     String    @default("all") @db.VarChar(50)
  sent_by    String?   @db.Uuid
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  users      users?    @relation(fields: [sent_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model applications {
  id                   String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  project_id           String              @db.Uuid
  student_id           String              @db.Uuid
  cover_letter         String
  estimated_completion DateTime            @db.Date
  offered_budget       Int?
  status               application_status? @default(pending)
  created_at           DateTime?           @default(now()) @db.Timestamptz(6)
  projects             projects            @relation(fields: [project_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users                users               @relation(fields: [student_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  contracts            contracts[]

  @@unique([project_id, student_id])
}

model contracts {
  id                                 String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  project_id                         String           @db.Uuid
  student_id                         String           @db.Uuid
  business_id                        String           @db.Uuid
  application_id                     String           @db.Uuid
  agreed_budget                      Int
  deadline                           DateTime         @db.Date
  status                             contract_status? @default(active)
  progress_pct                       Int?             @default(0)
  deliverable_url                    String?
  deliverable_notes                  String?
  started_at                         DateTime?        @default(now()) @db.Timestamptz(6)
  completed_at                       DateTime?        @db.Timestamptz(6)
  created_at                         DateTime?        @default(now()) @db.Timestamptz(6)

  applications                       applications     @relation(fields: [application_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users_contracts_business_idTousers users            @relation("contracts_business_idTousers", fields: [business_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  projects                           projects         @relation(fields: [project_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users_contracts_student_idTousers  users            @relation("contracts_student_idTousers", fields: [student_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  disputes                           disputes[]
  messages                           messages[]
  payments                           payments[]
  reviews                            reviews[]
  contract_deliverables              contract_deliverables[]
}

model disputes {
  id                                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  contract_id                       String    @db.Uuid
  opened_by                         String    @db.Uuid
  reason                            String
  evidence_url                      String?
  status                            String?   @default("open") @db.VarChar(50)
  admin_notes                       String?
  resolved_by                       String?   @db.Uuid
  created_at                        DateTime? @default(now()) @db.Timestamptz(6)
  resolved_at                       DateTime? @db.Timestamptz(6)
  contracts                         contracts @relation(fields: [contract_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users_disputes_opened_byTousers   users     @relation("disputes_opened_byTousers", fields: [opened_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users_disputes_resolved_byTousers users?    @relation("disputes_resolved_byTousers", fields: [resolved_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model messages {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  contract_id    String    @db.Uuid
  sender_id      String    @db.Uuid
  content        String
  attachment_url String?
  is_read        Boolean?  @default(false)
  created_at     DateTime? @default(now()) @db.Timestamptz(6)
  contracts      contracts @relation(fields: [contract_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users          users     @relation(fields: [sender_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model payments {
  id                             String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  contract_id                    String          @db.Uuid
  amount                         Int
  platform_fee                   Int             @default(0)
  net_amount                     Int
  status                         payment_status? @default(pending)
  payer_id                       String?         @db.Uuid
  payee_id                       String?         @db.Uuid
  held_at                        DateTime?       @db.Timestamptz(6)
  released_at                    DateTime?       @db.Timestamptz(6)
  proof_url                      String?
  created_at                     DateTime?       @default(now()) @db.Timestamptz(6)

  // ─── XENDIT INTEGRATION ───────────────────────────────────────
  // ID internal yang kita kirim ke Xendit sebagai external_id. Wajib UNIQUE
  // supaya webhook bisa idempotent (sama external_id = entity yang sama).
  // Format: "stairslife-pay-{payment_id}" — di-generate saat createInvoice.
  xendit_external_id             String?         @unique @db.VarChar(100)

  // ID invoice dari Xendit setelah create invoice sukses.
  xendit_invoice_id              String?         @db.VarChar(100)

  // URL hosted page Xendit (dibuka di FE supaya user bayar).
  xendit_invoice_url             String?

  // Metode pembayaran yang dipakai user (di-set saat webhook PAID masuk).
  // Contoh: "BCA", "QRIS", "OVO", "DANA", "CREDIT_CARD".
  payment_method                 String?         @db.VarChar(50)

  // Channel detail (mis. "BCA" untuk VA, "OVO" untuk e-wallet).
  payment_channel                String?         @db.VarChar(50)

  // Kapan invoice expired (Xendit default 24 jam). Setelah ini, user
  // tidak bisa bayar — harus generate invoice baru.
  expires_at                     DateTime?       @db.Timestamptz(6)

  // Kapan benar-benar dibayar (dari webhook). Berbeda dengan held_at
  // yang di-set saat kita process webhook (bisa beda detik).
  paid_at                        DateTime?       @db.Timestamptz(6)

  // Raw payload Xendit (webhook & response create) untuk audit/debug.
  // JSONB di Postgres, di-store sebagai unknown supaya Prisma tidak validasi.
  xendit_payload                 Json?

  // Refund tracking — di-set saat dispute resolution favor_business
  xendit_refund_id               String?         @db.VarChar(100)
  refunded_at                    DateTime?       @db.Timestamptz(6)

  contracts                      contracts       @relation(fields: [contract_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users_payments_payee_idTousers users?          @relation("payments_payee_idTousers", fields: [payee_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users_payments_payer_idTousers users?          @relation("payments_payer_idTousers", fields: [payer_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  // 1 kontrak = 1 payment. Mencegah 2 createInvoice konkuren membuat 2 invoice.
  @@unique([contract_id])
  @@index([status, created_at(sort: Desc)])
  @@index([xendit_invoice_id])
}

model projects {
  id              String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title           String          @db.VarChar(500)
  description     String
  budget_min      Int
  budget_max      Int
  deadline        DateTime        @db.Date
  category        String          @db.VarChar(100)
  tier            user_tier
  skills          String[]
  deliverables    String?
  status          project_status? @default(open)
  business_id     String          @db.Uuid
  applicant_count Int?            @default(0)
  created_at      DateTime?       @default(now()) @db.Timestamptz(6)
  updated_at      DateTime?       @default(now()) @db.Timestamptz(6)
  applications    applications[]
  contracts       contracts[]
  users           users           @relation(fields: [business_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model reviews {
  id                               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  contract_id                      String    @db.Uuid
  reviewer_id                      String    @db.Uuid
  reviewee_id                      String    @db.Uuid
  rating                           Int?
  comment                          String?
  tags                             String[]
  created_at                       DateTime? @default(now()) @db.Timestamptz(6)

  contracts                        contracts @relation(fields: [contract_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users_reviews_reviewee_idTousers users     @relation("reviews_reviewee_idTousers", fields: [reviewee_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users_reviews_reviewer_idTousers users     @relation("reviews_reviewer_idTousers", fields: [reviewer_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([contract_id, reviewer_id])
}

model users {
  id                                             String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  full_name                                      String          @db.VarChar(255)
  email                                          String          @unique @db.VarChar(255)
  password_hash                                  String?
  email_verified_at                              DateTime?       @db.Timestamptz(6)
  google_id                                      String?         @unique
  role                                           user_role
  tier                                           user_tier?      @default(pemula)
  is_verified                                    Boolean?        @default(false)
  avatar_url                                     String?
  bio                                            String?
  university                                     String?         @db.VarChar(255)
  major                                          String?         @db.VarChar(255)
  semester                                       Int?
  phone                                          String?         @db.VarChar(20)
  company_name                                   String?         @db.VarChar(255)
  business_type                                  String?         @db.VarChar(100)
  location                                       String?         @db.VarChar(255)
  skills                                         String[]
  portfolio_url                                  String?
  rating_avg                                     Decimal?        @default(0) @db.Decimal(3, 2)
  total_projects                                 Int?            @default(0)
  created_at                                     DateTime?       @default(now()) @db.Timestamptz(6)
  updated_at                                     DateTime?       @default(now()) @db.Timestamptz(6)
  is_suspended                                   Boolean?        @default(false)
  suspension_reason                              String?
  announcements                                  announcements[]
  applications                                   applications[]
  contracts_contracts_business_idTousers         contracts[]     @relation("contracts_business_idTousers")
  contracts_contracts_student_idTousers          contracts[]     @relation("contracts_student_idTousers")
  disputes_disputes_opened_byTousers             disputes[]      @relation("disputes_opened_byTousers")
  disputes_disputes_resolved_byTousers           disputes[]      @relation("disputes_resolved_byTousers")
  messages                                       messages[]
  payments_payments_payee_idTousers              payments[]      @relation("payments_payee_idTousers")
  payments_payments_payer_idTousers              payments[]      @relation("payments_payer_idTousers")
  projects                                       projects[]
  reviews_reviews_reviewee_idTousers             reviews[]       @relation("reviews_reviewee_idTousers")
  reviews_reviews_reviewer_idTousers             reviews[]       @relation("reviews_reviewer_idTousers")
  contract_deliverables                          contract_deliverables[]
  verifications_verifications_reviewed_byTousers verifications[] @relation("verifications_reviewed_byTousers")
  verifications_verifications_user_idTousers     verifications?  @relation("verifications_user_idTousers")
  support_messages                               support_messages[]
  notifications                                  notifications[]
  verification_tokens                            verification_tokens[]
  bank_accounts                                  bank_accounts[]
  withdrawals                                    withdrawals[]      @relation("withdrawals_user_idTousers")
  withdrawals_processed_by                       withdrawals[]      @relation("withdrawals_processed_byTousers")
  wallet                                         wallets?
}

// Token untuk email verification & password reset.
// Token hash (SHA-256) yang disimpan, BUKAN raw token.
// Token mentah hanya dikirim ke email user.
model verification_tokens {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id     String    @db.Uuid
  token_hash  String    @unique
  type        String    // 'email_verification' | 'password_reset'
  expires_at  DateTime  @db.Timestamptz(6)
  used_at     DateTime? @db.Timestamptz(6)
  created_at  DateTime  @default(now()) @db.Timestamptz(6)
  ip_address  String?
  user_agent  String?
  users       users     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, type])
  @@index([expires_at])
}

model verifications {
  id                                     String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id                                String               @unique @db.Uuid
  ktm_image_url                          String
  selfie_url                             String?
  university                             String               @db.VarChar(255)
  student_id_number                      String?              @db.VarChar(50)
  status                                 verification_status? @default(pending)
  reviewed_by                            String?              @db.Uuid
  rejection_reason                       String?
  submitted_at                           DateTime?            @default(now()) @db.Timestamptz(6)
  reviewed_at                            DateTime?            @db.Timestamptz(6)
  users_verifications_reviewed_byTousers users?               @relation("verifications_reviewed_byTousers", fields: [reviewed_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users_verifications_user_idTousers     users                @relation("verifications_user_idTousers", fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model contract_deliverables {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  contract_id       String    @db.Uuid
  deliverable_url   String
  deliverable_notes String?
  status            String?   @default("pending") @db.VarChar(50)
  rejection_reason  String?
  submitted_at      DateTime? @default(now()) @db.Timestamptz(6)
  reviewed_at       DateTime? @db.Timestamptz(6)
  reviewed_by       String?   @db.Uuid
  contracts         contracts @relation(fields: [contract_id], references: [id], onDelete: Cascade)
  users             users?    @relation(fields: [reviewed_by], references: [id])
}

model support_messages {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  room_id     String    @db.VarChar(255)
  sender_id   String?   @db.Uuid
  content     String
  sender_role String?   @default("user") @db.VarChar(50)
  created_at  DateTime? @default(now()) @db.Timestamptz(6)
  users       users?    @relation(fields: [sender_id], references: [id])
}

model platform_settings {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  key        String    @unique @db.VarChar(100)
  value      String
  updated_at DateTime? @default(now()) @db.Timestamptz(6)
}

// Notifikasi persisten — sebelumnya di-generate dinamis dari status record
// lain. Sekarang di-write ke tabel ini dan dipush via WebSocket ke client.
model notifications {
  id          String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id     String             @db.Uuid
  type        notification_type
  title       String             @db.VarChar(255)
  body        String
  // Soft-reference ke entity yang trigger notif (mis. contract_id, application_id).
  // Tidak FK karena polymorphic — type menentukan tabel mana.
  ref_id      String?            @db.Uuid
  // URL deep-link di FE (mis. "/contracts/abc-123").
  action_url  String?
  is_read     Boolean            @default(false)
  read_at     DateTime?          @db.Timestamptz(6)
  created_at  DateTime           @default(now()) @db.Timestamptz(6)
  users       users              @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  // Index untuk query umum: list notif user yang belum dibaca, urut waktu desc.
  @@index([user_id, is_read, created_at(sort: Desc)])
  @@index([user_id, created_at(sort: Desc)])
}

enum application_status {
  pending
  shortlisted
  approved
  rejected
}

enum contract_status {
  active
  pending_review
  completed
  disputed
}

enum payment_status {
  pending        // baru dibuat, user belum bayar (Xendit invoice belum di-paid)
  held           // sudah dibayar, dana di-escrow
  released       // dana sudah dicairkan ke saldo mahasiswa
  refunded       // dana di-refund ke bisnis (dispute favor_business)
  split_settled  // dana dibagi proporsional (dispute split)
  expired        // Xendit invoice expired tanpa pembayaran
  failed         // pembayaran gagal di Xendit
}

enum project_status {
  open
  inProgress
  completed
  disputed
  cancelled
}

enum user_role {
  mahasiswa
  bisnis
  admin
}

enum user_tier {
  pemula
  menengah
  mahir
}

enum verification_status {
  pending
  approved
  rejected
}

enum notification_type {
  application       // lamaran masuk / status berubah
  contract          // kontrak aktif / pending review / completed
  payment           // escrow held / released / refunded
  review            // dapat review baru
  dispute           // dispute opened / resolved
  verification      // KTM approved / rejected
  system            // pengumuman admin / banner
  withdrawal        // request / approved / rejected / completed
}

// ─── WALLET ────────────────────────────────────────────────
// Saldo virtual mahasiswa. Tidak FK ke escrow secara langsung — escrow
// release menambah saldo via wallet_transactions, withdrawal mengurangi.
model wallets {
  id              String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id         String     @unique @db.Uuid
  // Saldo yang bisa ditarik (sudah lewat escrow release).
  amount          BigInt     @default(0)
  // Saldo yang sedang di-lock karena withdrawal request belum di-approve.
  pending_amount  BigInt     @default(0)
  // Akumulasi histori untuk dashboard (tidak pernah turun).
  total_earned    BigInt     @default(0)
  total_withdrawn BigInt     @default(0)
  updated_at      DateTime   @default(now()) @db.Timestamptz(6)
  created_at      DateTime   @default(now()) @db.Timestamptz(6)
  users           users      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  transactions    wallet_transactions[]
}

model wallet_transactions {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  wallet_id   String   @db.Uuid
  user_id     String   @db.Uuid
  // Tipe transaksi — lihat enum di SQL migration.
  type        String   @db.VarChar(50)
  amount      BigInt
  ref_type    String?  @db.VarChar(50)
  ref_id      String?  @db.Uuid
  description String?
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  wallet      wallets  @relation(fields: [wallet_id], references: [id], onDelete: Cascade)

  // Idempotency-key: 1 (entity, id, aksi) hanya boleh tercatat sekali.
  // Insert kedua (mis. double-credit earn_release) melempar P2002 → transaksi
  // rollback → tidak ada increment ganda. Backstop level-DB lintas semua jalur.
  @@unique([ref_type, ref_id, type])
  @@index([wallet_id, created_at(sort: Desc)])
}

// ─── BANK ACCOUNT ─────────────────────────────────────────
// Mahasiswa register rekening untuk tujuan disbursement.
// 1 user bisa punya banyak rekening, 1 sebagai primary.
model bank_accounts {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id         String        @db.Uuid
  bank_name       String        @db.VarChar(100)
  // Kode bank untuk Xendit Disbursement API. Contoh: "BCA", "BNI", "MANDIRI", "BRI".
  bank_code       String        @db.VarChar(20)
  account_number  String        @db.VarChar(30)
  account_holder  String        @db.VarChar(255)
  is_primary      Boolean       @default(false)
  // Name-check via Xendit (Indonesia: ID Indonesia → Xendit accountname API).
  verified_at     DateTime?     @db.Timestamptz(6)
  created_at      DateTime      @default(now()) @db.Timestamptz(6)
  users           users         @relation(fields: [user_id], references: [id], onDelete: Cascade)
  withdrawals     withdrawals[]

  @@unique([user_id, account_number])
  @@index([user_id, is_primary])
}

// ─── WITHDRAWAL ───────────────────────────────────────────
// Request mahasiswa cair dari saldo ke rekening.
// MVP: admin approve manual → flag completed.
// Production: integrasi Xendit Disbursement, status diisi dari webhook.
model withdrawals {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id             String    @db.Uuid
  bank_account_id     String    @db.Uuid
  amount_gross        Int       // saldo yang dikurangi (termasuk fee)
  admin_fee           Int       @default(0)
  amount_net          Int       // yang sampai ke rekening user
  status              String    @default("pending") @db.VarChar(20)
  // ^ pending | processing | completed | rejected | failed
  rejection_reason    String?
  processed_by        String?   @db.Uuid
  processed_at        DateTime? @db.Timestamptz(6)
  // ID disbursement dari Xendit (kalau pakai API). Null kalau manual.
  xendit_disbursement_id String? @db.VarChar(100)
  xendit_payload      Json?
  requested_at        DateTime  @default(now()) @db.Timestamptz(6)
  bank_account        bank_accounts @relation(fields: [bank_account_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users               users         @relation("withdrawals_user_idTousers", fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users_processed_by  users?        @relation("withdrawals_processed_byTousers", fields: [processed_by], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([user_id, requested_at(sort: Desc)])
  @@index([status, requested_at])
}
