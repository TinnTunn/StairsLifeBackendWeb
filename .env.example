# ============================================================
# StairsLife Backend — Environment Variables
# Copy file ini menjadi `.env` dan isi nilai yang sesuai.
# JANGAN commit `.env` ke git.
# ============================================================

# --- Server ---
PORT=3000
NODE_ENV=development

# --- CORS ---
# URL frontend yang diizinkan akses API. Pisah dengan koma untuk multiple origin.
# Contoh: http://localhost:5173,https://stairslife.vercel.app
FRONTEND_URL=http://localhost:5173

# --- Database (PostgreSQL via Supabase) ---
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DBNAME

# --- Supabase ---
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# Service role key — punya akses penuh, JANGAN expose ke frontend.
SUPABASE_SERVICE_ROLE_KEY=

# --- JWT ---
# Generate dengan: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Minimal 64 karakter. Jangan pakai nilai placeholder.
JWT_SECRET=
JWT_EXPIRES_IN=7d

# --- Upload ---
# Public URL prefix untuk file upload. Default ke http://localhost:PORT bila kosong.
# Production contoh: https://api.stairslife.id
PUBLIC_BASE_URL=
